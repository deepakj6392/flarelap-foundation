datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int          @id @default(autoincrement())
  name         String?
  email        String       @unique
  password     String
  role         String       @default("user")
  createdAt    DateTime     @default(now()) @map("created_at")
  otpCode      String?      @map("otp_code")
  otpExpiresAt DateTime?    @map("otp_expires_at")
  tfaEnabled   Boolean?     @default(false) @map("tfa_enabled")
  tfaCode      String?      @map("tfa_code")
  tfaExpiresAt DateTime?    @map("tfa_expires_at")
  studentId    String?      @unique @map("student_id")
  phone        String?
  tempPassword String?      @map("temp_password")
  courseId     Int?         @map("course_id")
  course       Course?      @relation(fields: [courseId], references: [id])
  categoryId   Int?         @map("category_id")
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  logs         StudentLog[]
  purchases    Purchase[]
  testAttempts TestAttempt[]

  @@map("users")
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  post      String?  @default("Foundation Inquiry")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contacts")
}

model Newsletter {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  @@map("newsletter")
}

model Donation {
  id            Int      @id @default(autoincrement())
  name      String
  email     String
  phone         String?
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String   @map("payment_method")
  transactionId String?  @map("transaction_id")
  message       String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("donations")
}

model Course {
  id          Int           @id @default(autoincrement())
  name        String
  active      Boolean       @default(true)
  premium     Boolean       @default(false)
  price       Decimal       @default(59.00) @db.Decimal(12, 2)
  createdAt   DateTime      @default(now()) @map("created_at")
  categoryId  Int?          @map("category_id")
  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  users       User[]
  mcqs        MCQQuestion[]
  testSeries  TestSeries[]
  purchases   Purchase[]
  testAttempts TestAttempt[]

  @@map("courses")
}

model StudentLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // LOGIN or LOGOUT
  timestamp DateTime @default(now()) @map("timestamp")

  @@map("student_logs")
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String   @map("image_url")
  caption   String?  @default("")
  pageName  String   @default("General") @map("page_name")
  sequence  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("gallery_images")
}

model MCQQuestion {
  id        Int      @id @default(autoincrement())
  courseId  Int      @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  question  String
  options   String[]
  answer    Int      // 0-indexed correct option index
  hint      String?  @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("mcq_questions")
}

model TestSeries {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // Full Mock, Subject Test, Chapter Test, PYP
  qs        Int
  marks     Int
  duration  Int
  isFree    Boolean  @default(false) @map("is_free")
  courseId  Int      @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  testAttempts TestAttempt[]

  @@map("test_series")
}

model Purchase {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      Int      @map("course_id")
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12, 2)
  status        String   @default("COMPLETED") // PENDING, COMPLETED, FAILED
  paymentMethod String?  @map("payment_method")
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("purchases")
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  email     String   @default("contact@flarelap.org")
  phone     String   @default("+919729817600")
  address   String   @default("Flarelap Global Foundation\nSirsal (38) Kaithal, Haryana, India. PIN- 136026.")
  location  String   @default("India")
  facebook  String   @default("https://www.facebook.com/flarelap.org")
  instagram String   @default("https://www.instagram.com/flarelap_org")
  xLink     String   @default("https://x.com/Flarelap_Org") @map("x_link")
  youtube   String   @default("https://www.youtube.com/@flarelap_org")
  logoUrl   String?  @default("/logo.png") @map("logo_url") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model TeamMember {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  description String?
  imageUrl    String   @map("image_url")
  facebook    String?
  twitter     String?
  github      String?
  behance     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("team_members")
}

model TestAttempt {
  id          Int        @id @default(autoincrement())
  userId      Int        @map("user_id")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    Int        @map("course_id")
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  testId      Int        @map("test_id")
  test        TestSeries @relation(fields: [testId], references: [id], onDelete: Cascade)
  score       Decimal    @db.Decimal(6, 2)
  totalQs     Int        @map("total_qs")
  answered    Int
  correct     Int
  wrong       Int
  duration    Int        // Time taken in seconds
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("test_attempts")
}

model BlogPost {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  content      String   @db.Text
  thumbnail    String   @map("thumbnail")
  excerpt      String   @db.Text
  metaTitle    String?  @map("meta_title")
  metaDesc     String?  @map("meta_desc")
  keywords     String?  @map("keywords")
  published    Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  courses   Course[]
  users     User[]

  @@map("categories")
}

model Volunteer {
  id              Int      @id @default(autoincrement())
  memberId        String?  @unique @map("member_id")
  profilePhoto    String?  @map("profile_photo") @db.Text
  fullName        String   @map("full_name")
  gender          String
  dob             String
  panNo           String?  @map("pan_no")
  panCardDoc      String?  @map("pan_card_doc") @db.Text
  uidNo           String?  @map("uid_no")
  uidFrontDoc     String?  @map("uid_front_doc") @db.Text
  uidBackDoc      String?  @map("uid_back_doc") @db.Text
  email           String
  phone           String
  education       String
  specializations String?
  street          String?
  villageCity     String?  @map("village_city")
  district        String?
  state           String?
  pincode         String?
  agreement       Boolean  @default(true)
  status          String   @default("APPROVED")
  designation     String?  @default("Volunteer")
  memberSince     String?  @map("member_since")
  expiryDate      String?  @map("expiry_date")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("volunteers")
}

model UserLog {
  id            Int      @id @default(autoincrement())
  userId        Int?     @map("user_id")
  userDisplayId String   @map("user_display_id")
  userName      String   @map("user_name")
  email         String
  role          String   @default("STUDENT") // "ADMIN" | "STUDENT"
  action        String   @default("LOGIN") // "LOGIN" | "LOGOUT"
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("user_logs")
}



